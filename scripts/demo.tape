# DAO CODE 演示录制:vhs scripts/demo.tape(需 dao 在 PATH + DEEPSEEK_API_KEY 在环境里)
Output docs/demo.gif
Set Shell "zsh"
Set FontSize 16
Set Width 1180
Set Height 720
Set Theme "Dracula"
Set Padding 14
Set TypingSpeed 45ms

Hide
Type "cd /tmp/dao-demo && clear"
Enter
Show

Type "dao"
Enter
Sleep 5s
Type "实现 strutil.py 的 slugify,再跑 python test.py 验证通过"
Enter
Sleep 20s
Type "/exit"
Enter
Sleep 1500ms
